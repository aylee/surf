# Optional non-interactive Cloudflare authentication. `wrangler login` is the
# simplest local path; CI can set these values as encrypted secrets instead.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional ignored override for manually provisioned Cloudflare bindings.
SURF_WRANGLER_CONFIG=

# Used by the production smoke test and manual ingest helper.
SURF_BASE_URL=
SURF_INGEST_TOKEN=
